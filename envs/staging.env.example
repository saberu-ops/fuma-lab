# Staging environment for Fuma Lab - copy to envs/staging.env.
#   cp envs/staging.env.example envs/staging.env
# envs/staging.env is gitignored. The default staging model does not store a
# Cloudflare Tunnel token here; cloudflared runs as a host-level service.
#
# Host tunnel route:
#   stg.t3s7.com -> http://127.0.0.1:3001
#
# Deploy the staging app:
#   npm run deploy:stg
# or:
#   scripts/staging.sh deploy
# Both paths use scripts/deploy.sh --env staging so staging and production share
# rollback, health-check, and smoke-test behavior.

# --- Compose behaviour (read by docker compose itself from this file) ---
# Isolates staging from production: its own project (separate containers +
# network). The host cloudflared service forwards public traffic to DOCS_PORT.
COMPOSE_PROJECT_NAME=fuma-lab-stg

# --- Application image / build / runtime ---
# Separate tag so a staging build never overwrites the production image.
DOCS_IMAGE=fuma-lab:stg
# Baked into the image at build time (metadataBase -> canonical/OG/sitemap URLs).
SITE_URL=https://stg.t3s7.com
# Host port for local smoke tests and the host-managed tunnel.
DOCS_PORT=3001
# Emit X-Robots-Tag: noindex on every response (keep staging out of search).
ROBOTS_NOINDEX=1

# --- Optional fallback: compose-managed Cloudflare Tunnel ---
# Use only if the host cloudflared service is not managing stg.t3s7.com.
# COMPOSE_PROFILES=tunnel
# CLOUDFLARED_VERSION=latest
# TUNNEL_TOKEN=replace-with-staging-tunnel-token
