# Production environment for Fuma Lab — copy to envs/production.env when the
# production domain and environment settings are known:
#   cp envs/production.env.example envs/production.env
#
# Production's tunnel is a HOST cloudflared systemd service (not in compose), so
# the "tunnel" profile is intentionally NOT set here — compose starts only the
# app. Pinning the project name to fuma-lab documents/locks the target so a
# stray bare `docker compose` cannot be mistaken for staging.
#
# NOTE: the standard production deploy path is `npm run deploy` or
# `npm run deploy:prod` (scripts/deploy.sh --env production, with rollback).
# This file documents the prod knobs and guards against cross-environment
# mistakes.

COMPOSE_PROJECT_NAME=fuma-lab
# No COMPOSE_PROFILES — production does not run the compose cloudflared service.

DOCS_IMAGE=fuma-lab:prod
SITE_URL=https://your-production-domain.example
DOCS_PORT=3000
# ROBOTS_NOINDEX intentionally unset in production (pages should be indexable).
