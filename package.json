{
  "name": "fuma-lab",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "verify": "npm run lint && npm run docs:check && npm run types:check",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "oxlint",
    "subtitles:build": "python3 scripts/calibrate-listening-subtitles.py",
    "subtitles:check": "python3 scripts/calibrate-listening-subtitles.py --check",
    "audio:build": "node scripts/build-listening-exam.mjs",
    "note:new": "node scripts/new-japanese-note.mjs",
    "deploy": "bash scripts/deploy.sh",
    "deploy:prod": "bash scripts/deploy.sh --env production",
    "deploy:stg": "bash scripts/deploy.sh --env staging",
    "deploy:check": "bash scripts/deploy.sh --check-only",
    "deploy:stg:check": "bash scripts/deploy.sh --env staging --check-only",
    "docs:sync": "node scripts/sync-fumadocs-reference.mjs",
    "docs:check": "node scripts/sync-fumadocs-reference.mjs --check"
  },
  "dependencies": {
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.10.7",
    "fumadocs-mdx": "15.0.13",
    "fumadocs-ui": "16.10.7",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "oxlint": "^1.71.0"
  }
}
